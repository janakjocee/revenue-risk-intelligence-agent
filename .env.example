# Optional OpenAI-compatible API configuration.
# The project works without these values by using local deterministic fallbacks.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=tfidf

# Local project paths
DATA_DIR=data
MODEL_PATH=data/processed/churn_model.joblib
RETRIEVER_PATH=data/processed/tfidf_retriever.joblib
OBSERVABILITY_LOG_PATH=data/processed/agent_runs.jsonl
LOG_LEVEL=INFO
